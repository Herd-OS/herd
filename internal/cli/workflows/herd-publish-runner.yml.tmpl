name: Herd Publish Runner Image
on:
  # `push` rebuilds the wrapper image on every change to
  # Dockerfile.herd_runner — this is how a consumer repo automatically
  # picks up a new base-image version after merging an
  # `Update HerdOS to <tag>` PR (which bumps the `FROM
  # ghcr.io/herd-os/herd-runner-base:<version>` line). Without this
  # trigger, the wrapper image at `:latest` stays at whatever it was
  # last manually built, so worker containers continue to ship stale
  # baked-in agent CLIs (codex, claude, opencode) and stale
  # project-specific tools even after a herd upgrade.
  #
  # NOTE for the herd-os/herd repo itself: this can produce a duplicate
  # wrapper build when a release tag closely follows a wrapper-touching
  # PR — once via this push trigger, once via release.yml's
  # publish-runner-image job. That double-build is herd-os/herd-specific
  # and acceptable; consumer repos have no release.yml and would
  # otherwise have no auto-rebuild path at all.
  workflow_dispatch:
  push:
    paths:
      - 'Dockerfile.herd_runner'
    branches: [ main ]

permissions:
  contents: read
  packages: write

jobs:
  publish:
    if: vars.HERD_ENABLED == 'true'
    runs-on: {{ if eq (len .ImagePublish.RunsOn) 1 }}{{ yamlScalar (index .ImagePublish.RunsOn 0) }}{{ else }}[{{ range $i, $r := .ImagePublish.RunsOn }}{{ if $i }}, {{ end }}{{ yamlQuote $r }}{{ end }}]{{ end }}
    steps:
      - uses: actions/checkout@v4
{{- if gt (len .ImagePublish.Platforms) 1 }}
      - uses: docker/setup-qemu-action@v3
      - uses: docker/setup-buildx-action@v3
{{- end }}
      - uses: docker/login-action@v3
        with:
          registry: ghcr.io
          username: ${{`{{`}} github.actor {{`}}`}}
          password: ${{`{{`}} secrets.GITHUB_TOKEN {{`}}`}}
      - name: Build and push customized runner image
        run: |
          OWNER=$(echo "${{`{{`}} github.repository_owner {{`}}`}}" | tr '[:upper:]' '[:lower:]')
          REPO=$(echo "${{`{{`}} github.event.repository.name {{`}}`}}" | tr '[:upper:]' '[:lower:]')
          IMAGE=ghcr.io/${OWNER}/${REPO}-herd-runner
{{- if gt (len .ImagePublish.Platforms) 1 }}
          docker buildx build \
            --platform {{ joinPlatforms .ImagePublish.Platforms }} \
            -f Dockerfile.herd_runner \
            -t ${IMAGE}:latest \
            --push .
{{- else }}
          docker build --platform {{ index .ImagePublish.Platforms 0 }} -f Dockerfile.herd_runner -t ${IMAGE}:latest .
          docker push ${IMAGE}:latest
{{- end }}
