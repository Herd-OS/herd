name: HerdOS Integrator
on:
  workflow_run:{{if .Integrator.CIWorkflows}}
    workflows:
      - "HerdOS Worker"
{{range .Integrator.CIWorkflows}}      - {{yamlQuote .}}
{{end}}    types: [completed]
{{else}}
    workflows: ["HerdOS Worker"]
    types: [completed]
{{end}}  check_run:
    types: [completed]
  pull_request_review:
    types: [submitted]
  pull_request:
    types: [closed]
  issues:
    types: [closed]

permissions:
  contents: read
  id-token: write
  statuses: read
  checks: read

jobs:
  integrate:{{if .Integrator.CIWorkflows}}
    if: vars.HERD_ENABLED == 'true' && github.event_name == 'workflow_run' && github.event.workflow_run.conclusion != 'skipped' && github.event.workflow_run.path == '.github/workflows/herd-worker.yml'
{{else}}
    if: vars.HERD_ENABLED == 'true' && github.event_name == 'workflow_run' && github.event.workflow_run.conclusion != 'skipped'
{{end}}    concurrency:
      group: herd-integrate-${{`{{`}} github.event.workflow_run.head_branch || github.ref {{`}}`}}
      cancel-in-progress: false
    runs-on: [self-hosted, '${{`{{`}} vars.HERD_RUNNER_LABEL || ''herd-worker'' {{`}}`}}']
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Request hosted integration
        env:
          HERD_RUNNER: "true"
          HERD_CONTROL_PLANE_URL: {{if .ControlPlaneURL}}{{yamlScalar .ControlPlaneURL}}{{else}}${{`{{`}} vars.HERD_CONTROL_PLANE_URL || 'https://api.herd-os.com' {{`}}`}}{{end}}
          RUN_ID: ${{`{{`}} github.event.workflow_run.id {{`}}`}}
          RUN_CONCLUSION: ${{`{{`}} github.event.workflow_run.conclusion {{`}}`}}
          RUN_HEAD_BRANCH: ${{`{{`}} github.event.workflow_run.head_branch {{`}}`}}
          RUN_HEAD_SHA: ${{`{{`}} github.event.workflow_run.head_sha {{`}}`}}
          REPOSITORY: ${{`{{`}} github.repository {{`}}`}}
        run: |
          OIDC_TOKEN="$(curl -fsSL -H "Authorization: bearer $ACTIONS_ID_TOKEN_REQUEST_TOKEN" "${ACTIONS_ID_TOKEN_REQUEST_URL}&audience=herd-control-plane" | jq -r '.value')"
          jq -n \
            --arg repository "$REPOSITORY" \
            --arg event_name "workflow_run" \
            --arg action "worker_completed" \
            --arg run_id "$RUN_ID" \
            --arg conclusion "$RUN_CONCLUSION" \
            --arg head_branch "$RUN_HEAD_BRANCH" \
            --arg head_sha "$RUN_HEAD_SHA" \
            '{
              version: 1,
              kind: "integrator_event",
              repository: $repository,
              event_name: $event_name,
              action: $action,
              workflow_run: {
                id: $run_id,
                conclusion: $conclusion,
                head_branch: $head_branch,
                head_sha: $head_sha
              }
            }' \
            > /tmp/herd-integrator-event.json
          curl -fsSL -X POST \
            -H "Authorization: Bearer $OIDC_TOKEN" \
            -H "Content-Type: application/json" \
            --data-binary @/tmp/herd-integrator-event.json \
            "$HERD_CONTROL_PLANE_URL/api/v1/workflow-events"

{{if .Integrator.CIWorkflows}}
  check-ci-workflow-completion:
    if: vars.HERD_ENABLED == 'true' && github.event_name == 'workflow_run' && github.event.workflow_run.conclusion != 'skipped' && startsWith(github.event.workflow_run.head_branch, 'herd/batch/') && github.event.workflow_run.path != '.github/workflows/herd-worker.yml'
    concurrency:
      group: herd-integrate-${{`{{`}} github.event.workflow_run.head_branch || github.ref {{`}}`}}
      cancel-in-progress: false
    runs-on: [self-hosted, '${{`{{`}} vars.HERD_RUNNER_LABEL || ''herd-worker'' {{`}}`}}']
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          ref: ${{`{{`}} github.event.workflow_run.head_branch {{`}}`}}
          fetch-depth: 0

      - name: Request hosted CI reconciliation
        env:
          HERD_RUNNER: "true"
          HERD_CONTROL_PLANE_URL: {{if .ControlPlaneURL}}{{yamlScalar .ControlPlaneURL}}{{else}}${{`{{`}} vars.HERD_CONTROL_PLANE_URL || 'https://api.herd-os.com' {{`}}`}}{{end}}
          RUN_ID: ${{`{{`}} github.event.workflow_run.id {{`}}`}}
          HEAD_BRANCH: ${{`{{`}} github.event.workflow_run.head_branch {{`}}`}}
          RUN_CONCLUSION: ${{`{{`}} github.event.workflow_run.conclusion {{`}}`}}
          RUN_HEAD_SHA: ${{`{{`}} github.event.workflow_run.head_sha {{`}}`}}
          REPOSITORY: ${{`{{`}} github.repository {{`}}`}}
        run: |
          BATCH=$(echo "$HEAD_BRANCH" | grep -oP 'herd/batch/\K[0-9]+' || true)
          OIDC_TOKEN="$(curl -fsSL -H "Authorization: bearer $ACTIONS_ID_TOKEN_REQUEST_TOKEN" "${ACTIONS_ID_TOKEN_REQUEST_URL}&audience=herd-control-plane" | jq -r '.value')"
          jq -n \
            --arg repository "$REPOSITORY" \
            --arg event_name "workflow_run" \
            --arg action "ci_workflow_completed" \
            --arg run_id "$RUN_ID" \
            --arg batch "$BATCH" \
            --arg conclusion "$RUN_CONCLUSION" \
            --arg head_branch "$HEAD_BRANCH" \
            --arg head_sha "$RUN_HEAD_SHA" \
            '{
              version: 1,
              kind: "integrator_event",
              repository: $repository,
              event_name: $event_name,
              action: $action,
              batch_number: (if $batch == "" then null else ($batch | tonumber) end),
              workflow_run: {
                id: $run_id,
                conclusion: $conclusion,
                head_branch: $head_branch,
                head_sha: $head_sha
              }
            }' \
            > /tmp/herd-integrator-event.json
          curl -fsSL -X POST \
            -H "Authorization: Bearer $OIDC_TOKEN" \
            -H "Content-Type: application/json" \
            --data-binary @/tmp/herd-integrator-event.json \
            "$HERD_CONTROL_PLANE_URL/api/v1/workflow-events"

{{end}}  check-ci-on-completion:
    if: >
      vars.HERD_ENABLED == 'true'
      && github.event_name == 'check_run'
      && startsWith(github.event.check_run.check_suite.head_branch, 'herd/batch/')
    concurrency:
      group: herd-check-ci-${{`{{`}} github.event.check_run.check_suite.head_branch || github.ref {{`}}`}}
      cancel-in-progress: true
    runs-on: [self-hosted, '${{`{{`}} vars.HERD_RUNNER_LABEL || ''herd-worker'' {{`}}`}}']
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          ref: ${{`{{`}} github.event.check_run.check_suite.head_branch {{`}}`}}
          fetch-depth: 0

      - name: Request hosted CI reconciliation
        env:
          HERD_RUNNER: "true"
          HERD_CONTROL_PLANE_URL: {{if .ControlPlaneURL}}{{yamlScalar .ControlPlaneURL}}{{else}}${{`{{`}} vars.HERD_CONTROL_PLANE_URL || 'https://api.herd-os.com' {{`}}`}}{{end}}
          HEAD_BRANCH: ${{`{{`}} github.event.check_run.check_suite.head_branch {{`}}`}}
          CHECK_RUN_ID: ${{`{{`}} github.event.check_run.id {{`}}`}}
          CHECK_RUN_CONCLUSION: ${{`{{`}} github.event.check_run.conclusion {{`}}`}}
          CHECK_RUN_HEAD_SHA: ${{`{{`}} github.event.check_run.check_suite.head_sha {{`}}`}}
          REPOSITORY: ${{`{{`}} github.repository {{`}}`}}
        run: |
          BATCH=$(echo "$HEAD_BRANCH" | grep -oP 'herd/batch/\K[0-9]+' || true)
          OIDC_TOKEN="$(curl -fsSL -H "Authorization: bearer $ACTIONS_ID_TOKEN_REQUEST_TOKEN" "${ACTIONS_ID_TOKEN_REQUEST_URL}&audience=herd-control-plane" | jq -r '.value')"
          jq -n \
            --arg repository "$REPOSITORY" \
            --arg event_name "check_run" \
            --arg action "check_run_completed" \
            --arg check_run_id "$CHECK_RUN_ID" \
            --arg batch "$BATCH" \
            --arg conclusion "$CHECK_RUN_CONCLUSION" \
            --arg head_branch "$HEAD_BRANCH" \
            --arg head_sha "$CHECK_RUN_HEAD_SHA" \
            '{
              version: 1,
              kind: "integrator_event",
              repository: $repository,
              event_name: $event_name,
              action: $action,
              batch_number: (if $batch == "" then null else ($batch | tonumber) end),
              check_run: {
                id: $check_run_id,
                conclusion: $conclusion,
                head_branch: $head_branch,
                head_sha: $head_sha
              }
            }' \
            > /tmp/herd-integrator-event.json
          curl -fsSL -X POST \
            -H "Authorization: Bearer $OIDC_TOKEN" \
            -H "Content-Type: application/json" \
            --data-binary @/tmp/herd-integrator-event.json \
            "$HERD_CONTROL_PLANE_URL/api/v1/workflow-events"

  advance-on-close:
    if: vars.HERD_ENABLED == 'true' && github.event_name == 'issues'
    concurrency:
      # Closed herd issues do not expose a PR number at expression time; use the milestone when present.
      group: herd-advance-${{`{{`}} github.event.issue.milestone && github.event.issue.milestone.number || github.event.issue.number {{`}}`}}
      cancel-in-progress: false
    runs-on: [self-hosted, '${{`{{`}} vars.HERD_RUNNER_LABEL || ''herd-worker'' {{`}}`}}']
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Request hosted issue-close reconciliation
        env:
          HERD_RUNNER: "true"
          HERD_CONTROL_PLANE_URL: {{if .ControlPlaneURL}}{{yamlScalar .ControlPlaneURL}}{{else}}${{`{{`}} vars.HERD_CONTROL_PLANE_URL || 'https://api.herd-os.com' {{`}}`}}{{end}}
          ISSUE_NUMBER: ${{`{{`}} github.event.issue.number {{`}}`}}
          REPOSITORY: ${{`{{`}} github.repository {{`}}`}}
        run: |
          ISSUE_BODY="$(jq -r '.issue.body // ""' "$GITHUB_EVENT_PATH")"
          BATCH=$(echo "$ISSUE_BODY" | grep -oP '^\s*batch:\s*\K[0-9]+' | head -1 || true)
          if [ -n "$BATCH" ]; then
            OIDC_TOKEN="$(curl -fsSL -H "Authorization: bearer $ACTIONS_ID_TOKEN_REQUEST_TOKEN" "${ACTIONS_ID_TOKEN_REQUEST_URL}&audience=herd-control-plane" | jq -r '.value')"
            jq -n \
              --arg repository "$REPOSITORY" \
              --arg event_name "issues" \
              --arg action "issue_closed" \
              --argjson issue_number "$ISSUE_NUMBER" \
              --argjson batch_number "$BATCH" \
              '{
                version: 1,
                kind: "integrator_event",
                repository: $repository,
                event_name: $event_name,
                action: $action,
                issue_number: $issue_number,
                batch_number: $batch_number
              }' \
              > /tmp/herd-integrator-event.json
            curl -fsSL -X POST \
              -H "Authorization: Bearer $OIDC_TOKEN" \
              -H "Content-Type: application/json" \
              --data-binary @/tmp/herd-integrator-event.json \
              "$HERD_CONTROL_PLANE_URL/api/v1/workflow-events"
          else
            echo "Not a herd issue — skipping."
          fi

  re-review:
    if: >
      vars.HERD_ENABLED == 'true'
      && github.event_name == 'pull_request_review'
      && startsWith(github.event.pull_request.title, '[herd]')
    concurrency:
      group: herd-re-review-${{`{{`}} github.event.pull_request.number {{`}}`}}
      cancel-in-progress: false
    runs-on: [self-hosted, '${{`{{`}} vars.HERD_RUNNER_LABEL || ''herd-worker'' {{`}}`}}']
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          ref: ${{`{{`}} github.event.pull_request.head.ref {{`}}`}}
          fetch-depth: 0

      - name: Request hosted review reconciliation
        env:
          HERD_RUNNER: "true"
          HERD_CONTROL_PLANE_URL: {{if .ControlPlaneURL}}{{yamlScalar .ControlPlaneURL}}{{else}}${{`{{`}} vars.HERD_CONTROL_PLANE_URL || 'https://api.herd-os.com' {{`}}`}}{{end}}
          REVIEW_STATE: ${{`{{`}} github.event.review.state {{`}}`}}
          PR_NUMBER: ${{`{{`}} github.event.pull_request.number {{`}}`}}
          PR_HEAD_SHA: ${{`{{`}} github.event.pull_request.head.sha {{`}}`}}
          REPOSITORY: ${{`{{`}} github.repository {{`}}`}}
        run: |
          OIDC_TOKEN="$(curl -fsSL -H "Authorization: bearer $ACTIONS_ID_TOKEN_REQUEST_TOKEN" "${ACTIONS_ID_TOKEN_REQUEST_URL}&audience=herd-control-plane" | jq -r '.value')"
          jq -n \
            --arg repository "$REPOSITORY" \
            --arg event_name "pull_request_review" \
            --arg action "review_submitted" \
            --arg review_state "$REVIEW_STATE" \
            --argjson pr_number "$PR_NUMBER" \
            --arg head_sha "$PR_HEAD_SHA" \
            '{
              version: 1,
              kind: "integrator_event",
              repository: $repository,
              event_name: $event_name,
              action: $action,
              pr_number: $pr_number,
              review_state: $review_state,
              head_sha: $head_sha
            }' \
            > /tmp/herd-integrator-event.json
          curl -fsSL -X POST \
            -H "Authorization: Bearer $OIDC_TOKEN" \
            -H "Content-Type: application/json" \
            --data-binary @/tmp/herd-integrator-event.json \
            "$HERD_CONTROL_PLANE_URL/api/v1/workflow-events"

  cleanup:
    if: >
      vars.HERD_ENABLED == 'true'
      && github.event_name == 'pull_request'
      && github.event.action == 'closed'
      && startsWith(github.event.pull_request.title, '[herd]')
    concurrency:
      group: herd-cleanup-${{`{{`}} github.event.pull_request.number {{`}}`}}
      cancel-in-progress: false
    runs-on: [self-hosted, '${{`{{`}} vars.HERD_RUNNER_LABEL || ''herd-worker'' {{`}}`}}']
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Request hosted cleanup
        env:
          HERD_RUNNER: "true"
          HERD_CONTROL_PLANE_URL: {{if .ControlPlaneURL}}{{yamlScalar .ControlPlaneURL}}{{else}}${{`{{`}} vars.HERD_CONTROL_PLANE_URL || 'https://api.herd-os.com' {{`}}`}}{{end}}
          PR_NUMBER: ${{`{{`}} github.event.pull_request.number {{`}}`}}
          PR_MERGED: ${{`{{`}} github.event.pull_request.merged {{`}}`}}
          REPOSITORY: ${{`{{`}} github.repository {{`}}`}}
        run: |
          OIDC_TOKEN="$(curl -fsSL -H "Authorization: bearer $ACTIONS_ID_TOKEN_REQUEST_TOKEN" "${ACTIONS_ID_TOKEN_REQUEST_URL}&audience=herd-control-plane" | jq -r '.value')"
          jq -n \
            --arg repository "$REPOSITORY" \
            --arg event_name "pull_request" \
            --arg action "pull_request_closed" \
            --argjson pr_number "$PR_NUMBER" \
            --argjson merged "$PR_MERGED" \
            '{
              version: 1,
              kind: "integrator_event",
              repository: $repository,
              event_name: $event_name,
              action: $action,
              pr_number: $pr_number,
              merged: $merged
            }' \
            > /tmp/herd-integrator-event.json
          curl -fsSL -X POST \
            -H "Authorization: Bearer $OIDC_TOKEN" \
            -H "Content-Type: application/json" \
            --data-binary @/tmp/herd-integrator-event.json \
            "$HERD_CONTROL_PLANE_URL/api/v1/workflow-events"
