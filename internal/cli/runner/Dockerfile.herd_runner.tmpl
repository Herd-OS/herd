# HerdOS Runner — project customization
# This file is yours to customize — herd init will never overwrite it.
#
# Base image: {{.BaseImage}}
# The base image is ghcr.io/herd-os/herd-runner-base (minimal — OS + runner only).
#
# To add tools on top of the base image (e.g., a Postgres client, ImageMagick,
# a language toolchain), add RUN apt-get install lines below.
#
# To use a different base, edit the FROM line below.
#
# DO NOT COPY source code (checked out at job time) or bake in secrets.

FROM {{.BaseImage}}

# The base image runs as the 'runner' user. Switch to root to install
# packages, then switch back when done.
USER root

# Examples — uncomment what your project needs:
#
# RUN apt-get update && apt-get install -y postgresql-client && rm -rf /var/lib/apt/lists/*

USER runner
