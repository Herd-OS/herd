# HerdOS runner configuration (herd-managed — regenerated by `herd init`)
# 1. Copy .env.herd.example to .env and fill in your tokens
# 2. Customize Dockerfile.herd_runner with project-specific tools
# 3. Build:  docker compose -f docker-compose.herd.yml build
# 4. Start:  docker compose -f docker-compose.herd.yml up -d
# 5. Scale:  docker compose -f docker-compose.herd.yml up -d --scale worker=5
# 6. Stop:   docker compose -f docker-compose.herd.yml down
#
# For project-specific overrides (build args, volumes, extra env vars),
# create docker-compose.herd.override.yml — `herd init` merges it into
# this file automatically. The override file is never overwritten.

services:
  worker:
    build:
      dockerfile: Dockerfile.herd_runner
    restart: always
    environment:
      - REPO_URL=https://github.com/{{.Owner}}/{{.Repo}}
      - HERD_RUNNER_BOOTSTRAP_TOKEN=${HERD_RUNNER_BOOTSTRAP_TOKEN}
{{- if .ControlPlaneURL }}
      - "HERD_CONTROL_PLANE_URL={{.ControlPlaneURL}}"
{{- end }}
      - RUNNER_LABELS=herd-worker
      # Optional UID/GID remap — see .env.herd.example. Defaults to 1001/1001
      # (the image's build-time UID/GID) when unset.
      - RUNNER_UID=${RUNNER_UID:-}
      - RUNNER_GID=${RUNNER_GID:-}
      # Claude provider auth
      - CLAUDE_CODE_OAUTH_TOKEN=${CLAUDE_CODE_OAUTH_TOKEN:-}
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}
      # Codex provider auth
      - CODEX_ACCESS_TOKEN=${CODEX_ACCESS_TOKEN:-}
      - HERD_CODEX_KEEPALIVE_INTERVAL=${HERD_CODEX_KEEPALIVE_INTERVAL:-}
      - HERD_VERSION=${HERD_VERSION:-}
      - HERD_AGENT_DEBUG=${HERD_AGENT_DEBUG:-}
    # Default to 3 runner replicas so a stock install matches the
    # workers.max_concurrent default of 3 (one self-hosted runner processes one
    # job at a time). To run N parallel Codex subscription workers, run
    # `docker compose up -d --scale worker=N` — all containers share the single
    # codex-auth volume below.
    deploy:
      replicas: 3
    volumes:
      - codex-auth:/home/runner/.codex

volumes:
  codex-auth:
